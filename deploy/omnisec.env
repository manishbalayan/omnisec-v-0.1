# =============================================================================
# OmniSec configuration
# =============================================================================
# Single source of truth for all OmniSec services. Sourced by the service
# launchers in /usr/local/libexec/omnisec/ (auto-exported into the process
# environment). The installer fills in machine-specific values (paths, ports,
# API key) at install time.
#
# Everything binds to loopback (127.0.0.1) — OmniSec is a host-native control
# plane and never exposes its data plane to the network.
# =============================================================================

# --- Connection endpoints (loopback only) -----------------------------------
DATABASE_URL=postgres://omnisec:omnisec@127.0.0.1:5432/omnisec
NATS_URL=nats://127.0.0.1:4222

# --- Service bind addresses / ports (loopback only) --------------------------
API_BIND=127.0.0.1:3002
DAEMON_HEALTH_BIND=127.0.0.1:3003
DASHBOARD_PORT=3000
NATS_PORT=4222

# --- Data + runtime locations (set per-OS by the installer) ------------------
OMNISEC_PGDATA=/var/lib/omnisec/postgres
OMNISEC_NATS_STORE=/var/lib/omnisec/nats
OMNISEC_PGBIN=/usr/lib/postgresql/16/bin
OMNISEC_DASHBOARD_DIR=/opt/omnisec/dashboard

# --- Dashboard → API URL used by the browser ---------------------------------
NEXT_PUBLIC_API_URL=http://127.0.0.1:3002

# --- Enforcement modes (0 = full enforcement) --------------------------------
OMNISEC_SAFE_MODE=0
OMNISEC_RECOMMENDATION_ONLY=0

# --- API authentication (generated by the installer if empty) ----------------
OMNISEC_API_KEY=

# --- Logging -----------------------------------------------------------------
RUST_LOG=info
